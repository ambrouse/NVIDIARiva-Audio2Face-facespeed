BACKEND_HOST=127.0.0.1
BACKEND_PORT=6320
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=6310
FACESPEED_PROXY_HOST=127.0.0.1
FACESPEED_PROXY_PORT=6300
TMUX_PREFIX=facespeed-riva
TMUX_DOCKER_SESSION=facespeed-riva-docker
TMUX_BACKEND_SESSION=facespeed-riva-backend
TMUX_FRONTEND_SESSION=facespeed-riva-frontend
TMUX_RIVA_TTS_SESSION=facespeed-riva-tts
TMUX_RIVA_ASR_SESSION=facespeed-riva-asr
PROJECT_COMPOSE_NAME=nvidiariva-audio2face-facespeed
RIVA_HOST=127.0.0.1
RIVA_PORT=6051
A2F_HOST=127.0.0.1
A2F_PORT=6040
A2F_HTTP_PORT=6041
LOG_DIR=logs
OUTPUT_DIR=outputs
SERVICE_MANAGER_MODE=docker
PIPELINE_MODE=riva
RIVA_DEFAULT_VOICE=English-US.Female-1
RIVA_SAMPLE_RATE_HZ=44100
RIVA_TTS_MAX_CONCURRENCY=1
RIVA_ASR_ENABLED=true
RIVA_ASR_HOST=127.0.0.1
RIVA_ASR_PORT=6052
RIVA_ASR_TIMEOUT_SECONDS=30
RIVA_ASR_LANGUAGE=en-US
RIVA_ASR_SAMPLE_RATE_HZ=16000
A2F_TRANSPORT=grpc
A2F_PROCESS_PATH=/api/process-audio
A2F_TIMEOUT_SECONDS=120
A2F_GRPC_CHUNK_SECONDS=1
A2F_GRPC_MAX_AUDIO_SECONDS=300
ALLOWED_ORIGINS=http://127.0.0.1:6310,http://localhost:6310
RESOURCE_RESERVE_PERCENT=10
GPU_MIN_FREE_VRAM_PERCENT=10
# VRAM note from 2026-05-25 benchmark evidence:
# GPU total 48,935 MiB; max observed used 39,833 MiB; min free 8,574 MiB.
# Baseline snapshot before final provider runtime used 35,827 MiB, so the
# FaceSpeed incremental workload estimate is about 4,006 MiB. Keep about
# 9,000 MiB free before start so the workload and 10% reserve both fit.
PROJECT_VRAM_TOTAL_MIB=48935
PROJECT_VRAM_OBSERVED_MAX_USED_MIB=39833
PROJECT_VRAM_OBSERVED_MIN_FREE_MIB=8574
PROJECT_VRAM_EXPECTED_MIB=4000
PROJECT_VRAM_RECOMMENDED_FREE_MIB=9000
RAM_MIN_FREE_PERCENT=10
DISK_MIN_FREE_PERCENT=10
NVIDIA_CACHE_DIR=.cache/nvidia
RIVA_ASSET_DIR=.cache/nvidia/riva
RIVA_QUICKSTART_DIR=.cache/nvidia/riva/riva_quickstart_v2.19.0
RIVA_TTS_CONFIG=.cache/nvidia/riva/config-facespeed-tts-6051.sh
RIVA_ASR_CONFIG=.cache/nvidia/riva/config-facespeed-asr-6052.sh
A2F_ASSET_DIR=.cache/nvidia/audio2face
A2F_OPEN_MODEL_DIR=.cache/nvidia/audio2face-v3.0
A2F_BROWSER_MODEL=/models/readyplayer-talk-arkit.glb
VITE_FACE_MODEL_URL=/models/readyplayer-talk-arkit.glb
DOCLING_API_BASE_URL=http://127.0.0.1:8005
EMBEDDING_API_BASE_URL=http://127.0.0.1:8006
DOCLING_TIMEOUT_SECONDS=180
EMBEDDING_TIMEOUT_SECONDS=30
RERANK_TIMEOUT_SECONDS=30
RAG_STORAGE_DIR=storage/rag
RAG_MIN_VECTOR_SCORE=0.2
RAG_MIN_CONFIDENCE=0.45
RAG_GRAPH_EXPANSION_DEPTH=2
RAG_GRAPH_MAX_CONTEXT_CHUNKS=10
RAG_REINDEX_ON_LOAD=false
RAG_EMBEDDING_BATCH_SIZE=2
RAG_EMBEDDING_BATCH_DELAY_SECONDS=1.0
POSTGRES_DSN=postgresql://facespeed:facespeed_dev_password@127.0.0.1:6001/facespeed
QDRANT_URL=http://127.0.0.1:6002
QDRANT_COLLECTION=facespeed_chunks
LLM_ENABLED=true
LLM_API_BASE_URL=http://127.0.0.1:8007/v1
LLM_MODEL=google/gemma-4-E4B-it
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
VOICE_CHAT_MAX_AUDIO_SECONDS=45
VOICE_CHAT_TTS_MAX_CHARS=150
PDF_MAX_UPLOAD_MB=20
DOCKER_CLEANUP_MODE=unused-only
PORT_CONFLICT_MODE=ask
PROJECT_DOCKER_LABEL=com.facespeed.project=NVIDIARiva-Audio2Face-facespeed
RIVA_CONTAINER_NAME=facespeed-riva
A2F_CONTAINER_NAME=facespeed-audio2face-3d
RIVA_CONTAINER_IMAGE=
A2F_CONTAINER_IMAGE=nvcr.io/nim/nvidia/audio2face-3d:2.0
A2F_CONTAINER_GRPC_PORT=52000
A2F_CONTAINER_HTTP_PORT=8000
CONTAINER_MEMORY_LIMIT=16g
CONTAINER_CPU_LIMIT=8
GPU_DEVICE_FLAG=--gpus device=0
DOCKER_COMMAND_TIMEOUT_SECONDS=30
