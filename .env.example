BACKEND_HOST=127.0.0.1
BACKEND_PORT=8020
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=6310
RIVA_HOST=127.0.0.1
RIVA_PORT=50051
A2F_HOST=127.0.0.1
A2F_PORT=8040
A2F_HTTP_PORT=8041
LOG_DIR=logs
OUTPUT_DIR=outputs
SERVICE_MANAGER_MODE=docker
PIPELINE_MODE=riva
RIVA_DEFAULT_VOICE=English-US.Female-1
RIVA_SAMPLE_RATE_HZ=22050
RIVA_ASR_ENABLED=true
RIVA_ASR_HOST=127.0.0.1
RIVA_ASR_PORT=50151
RIVA_ASR_TIMEOUT_SECONDS=30
RIVA_ASR_LANGUAGE=en-US
RIVA_ASR_SAMPLE_RATE_HZ=16000
A2F_TRANSPORT=grpc
A2F_PROCESS_PATH=/api/process-audio
A2F_TIMEOUT_SECONDS=120
A2F_GRPC_CHUNK_SECONDS=1
A2F_GRPC_MAX_AUDIO_SECONDS=300
ALLOWED_ORIGINS=http://127.0.0.1:6310,http://localhost:6310
RESOURCE_RESERVE_PERCENT=10
GPU_MIN_FREE_VRAM_PERCENT=10
RAM_MIN_FREE_PERCENT=10
DISK_MIN_FREE_PERCENT=10
NVIDIA_CACHE_DIR=.cache/nvidia
RIVA_ASSET_DIR=.cache/nvidia/riva
A2F_ASSET_DIR=.cache/nvidia/audio2face
A2F_OPEN_MODEL_DIR=.cache/nvidia/audio2face-v3.0
A2F_BROWSER_MODEL=/models/readyplayer-talk-arkit.glb
VITE_FACE_MODEL_URL=/models/readyplayer-talk-arkit.glb
DOCLING_API_BASE_URL=http://127.0.0.1:8005
EMBEDDING_API_BASE_URL=http://127.0.0.1:8006
DOCLING_TIMEOUT_SECONDS=60
EMBEDDING_TIMEOUT_SECONDS=30
RERANK_TIMEOUT_SECONDS=30
RAG_STORAGE_DIR=storage/rag
RAG_MIN_VECTOR_SCORE=0.2
RAG_MIN_CONFIDENCE=0.45
VOICE_CHAT_MAX_AUDIO_SECONDS=45
PDF_MAX_UPLOAD_MB=20
DOCKER_CLEANUP_MODE=unused-only
PORT_CONFLICT_MODE=ask
PROJECT_DOCKER_LABEL=com.facespeed.project=NVIDIARiva-Audio2Face-facespeed
RIVA_CONTAINER_NAME=facespeed-riva
A2F_CONTAINER_NAME=facespeed-audio2face-3d
RIVA_CONTAINER_IMAGE=
A2F_CONTAINER_IMAGE=nvcr.io/nim/nvidia/audio2face-3d:2.0
A2F_CONTAINER_GRPC_PORT=52000
A2F_CONTAINER_HTTP_PORT=8000
CONTAINER_MEMORY_LIMIT=16g
CONTAINER_CPU_LIMIT=8
GPU_DEVICE_FLAG=--gpus device=0
DOCKER_COMMAND_TIMEOUT_SECONDS=30
